# speciesmap.org — environment variables
# Copy this to .env and fill in values
# Never commit .env to GitHub

# Database — use internal URL when running in Coolify
DATABASE_URL=postgres://speciesmap_db:PASSWORD@hostname:5432/speciesmap_db

# Environment
ENVIRONMENT=production

# CORS
CORS_ORIGINS=https://speciesmap.org,https://*.speciesmap.org

# Map — get a free key at maptiler.com
VITE_MAPTILER_KEY=your_maptiler_key_here

# API base URL for Vue (leave empty to use relative URLs in production)
VITE_API_URL=
